{
  "name": "humming",
  "version": "0.1.0",
  "description": "Plugin-first lightweight BFF core for Bun with routes, options, and forward hooks.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "homepage": "https://github.com/vinono/humming#readme",
  "bugs": {
    "url": "https://github.com/vinono/humming/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vinono/humming.git"
  },
  "keywords": [
    "bff",
    "bun",
    "hono",
    "plugin",
    "proxy",
    "typescript"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "bun --watch src/main.ts",
    "prepack": "bun run build",
    "start": "bun src/main.ts",
    "example:basic": "bun examples/basic/main.ts",
    "example:with-async-plugin": "bun examples/with-async-plugin/main.ts",
    "example:with-plugins": "bun examples/with-plugins/main.ts",
    "test:consumer": "bun test consumer.test.ts",
    "test:entry": "bun test index.test.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "example:with-forward": "bun examples/with-forward/main.ts"
  },
  "dependencies": {
    "hono": "^4.12.9",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.8.3"
  },
  "packageManager": "bun@1.3.11"
}
