{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": [
    "index.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/main.ts"
  ]
}
